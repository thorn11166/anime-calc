<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AnimeCalc" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/accent_pink</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorSecondaryVariant">@color/accent_gold</item>
        <item name="android:colorBackground">@color/background_light</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/accent_pink</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.AnimeCalc.Dark" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/accent_pink</item>
        <item name="colorPrimaryVariant">@color/accent_pink</item>
        <item name="colorSecondary">@color/accent_cyan</item>
        <item name="colorSecondaryVariant">@color/accent_gold</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary_dark</item>
        <item name="android:textColorSecondary">@color/text_secondary_dark</item>
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
