<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background_light">

    <!-- Display -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/display_background"
        android:elevation="8dp">

        <EditText
            android:id="@+id/displayEdit"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="0"
            android:textSize="48sp"
            android:textColor="@color/text_primary"
            android:gravity="end|center_vertical"
            android:paddingEnd="16dp"
            android:paddingStart="16dp"
            android:inputType="none"
            android:cursorVisible="false"
            android:background="@android:color/transparent"
            android:fontFamily="@font/poppins_bold" />

        <!-- Anime mascot -->
        <ImageView
            android:id="@+id/mascot"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/mascot_happy"
            android:layout_gravity="start|center_vertical"
            android:contentDescription="Cute mascot" />

    </FrameLayout>

    <!-- Button Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="4"
        android:rowCount="5"
        android:horizontalSpacing="8dp"
        android:verticalSpacing="8dp">

        <!-- Row 1: Clear, Backspace, Percent, Divide -->
        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="C"
            android:textSize="20sp"
            android:background="@drawable/button_special"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnBackspace"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="⌫"
            android:textSize="20sp"
            android:background="@drawable/button_special"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnPercent"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="%"
            android:textSize="20sp"
            android:background="@drawable/button_operation"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnDivide"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="÷"
            android:textSize="24sp"
            android:background="@drawable/button_operation"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <!-- Row 2: 7, 8, 9, Multiply -->
        <Button
            android:id="@+id/btn7"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="7"
            android:textSize="20sp"
            android:background="@drawable/button_number"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn8"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="8"
            android:textSize="20sp"
            android:background="@drawable/button_number"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn9"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="9"
            android:textSize="20sp"
            android:background="@drawable/button_number"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnMultiply"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="×"
            android:textSize="24sp"
            android:background="@drawable/button_operation"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <!-- Row 3: 4, 5, 6, Minus -->
        <Button
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="4"
            android:textSize="20sp"
            android:background="@drawable/button_number"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn5"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="5"
            android:textSize="20sp"
            android:background="@drawable/button_number"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn6"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="6"
            android:textSize="20sp"
            android:background="@drawable/button_number"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnMinus"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="−"
            android:textSize="24sp"
            android:background="@drawable/button_operation"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <!-- Row 4: 1, 2, 3, Plus -->
        <Button
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="1"
            android:textSize="20sp"
            android:background="@drawable/button_number"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="2"
            android:textSize="20sp"
            android:background="@drawable/button_number"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btn3"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="3"
            android:textSize="20sp"
            android:background="@drawable/button_number"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnPlus"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="+"
            android:textSize="24sp"
            android:background="@drawable/button_operation"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <!-- Row 5: 0, Dot, Equals -->
        <Button
            android:id="@+id/btn0"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="2"
            android:text="0"
            android:textSize="20sp"
            android:background="@drawable/button_number"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnDot"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="."
            android:textSize="24sp"
            android:background="@drawable/button_number"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnEquals"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:text="="
            android:textSize="24sp"
            android:background="@drawable/button_equals"
            android:textColor="@color/white"
            android:stateListAnimator="@null" />

    </GridLayout>

</LinearLayout>
