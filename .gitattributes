# Auto detect text files and normalize line endings to LF
* text=auto

# Kotlin files
*.kt text eol=lf
*.kts text eol=lf

# Android resources
*.xml text eol=lf
*.json text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.apk binary
*.aab binary
*.ttf binary
*.otf binary
*.png binary
*.jpg binary
*.gif binary
*.webp binary

# Gradle
gradlew text eol=lf
gradlew.bat text eol=crlf
